{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://beans-cafe-backend.onrender.com/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://beans-cafe-backend.onrender.com/uploads/$1"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/admin/$1"
        },
        {
            "source": "/pages/(.*)",
            "destination": "/pages/$1"
        },
        {
            "source": "/css/(.*)",
            "destination": "/css/$1"
        },
        {
            "source": "/script/(.*)",
            "destination": "/script/$1"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ]
}